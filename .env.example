# Labex 环境变量配置示例
# 复制此文件为 .env 并填入真实的配置值

# ========== 数据库配置 ==========
# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=labex
MYSQL_USERNAME=root
MYSQL_PASSWORD=your_mysql_password_here

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# ========== 安全配置 ==========
# JWT 密钥（至少 64 字节）
JWT_SECRET=your_jwt_secret_key_here_at_least_64_bytes_long_for_security

# ========== AI 服务配置 ==========
# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_HOST=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7-highspeed

# Tavily 搜索 API（可选）
TAVILY_API_KEY=

# ========== 服务配置 ==========
# 嵌入服务地址
EMBEDDING_SERVICE_URL=http://localhost:5000

# 文件上传路径
UPLOAD_PATH=D:/workfordasan/uploads
CODE_EXEC_BASE_PATH=D:/workfordasan/code_exec
CLASS_DOCS_PATH=D:/workfordasan/Class-docs

# ========== 服务器配置 ==========
SERVER_PORT=8080
