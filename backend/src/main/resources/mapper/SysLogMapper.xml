<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.labex.mapper.SysLogMapper">

    <select id="selectPageList" resultType="com.labex.entity.SysLog">
        SELECT * FROM t_sys_log
        ORDER BY time DESC
        LIMIT #{offset}, #{limit}
    </select>

</mapper>
